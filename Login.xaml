<Window x:Class="Nimaime.SPD.Login"
				xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				xmlns:local="clr-namespace:Nimaime.SPD"
				xmlns:hc="https://handyorg.github.io/handycontrol"
				mc:Ignorable="d"
				Title="登录" Height="180" Width="360"
				ResizeMode="NoResize">
	<Grid Margin="5">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<!--ACCOUNT-->
		<Grid Grid.Row="0">
			<TextBox Name="txtAccount" VerticalAlignment="Center"
							 hc:InfoElement.TitlePlacement="Left"
							 hc:InfoElement.Title="账号"
							 Style="{StaticResource TextBoxExtend}"/>
		</Grid>
		<!--PASSWORD-->
		<Grid Grid.Row="1" Margin="0,5,0,0">
			<PasswordBox Name="txtPassword" VerticalAlignment="Center"
									 hc:InfoElement.TitlePlacement="Left"
									 hc:InfoElement.Title="密码"
									 Style="{StaticResource PasswordBoxExtend}"/>
		</Grid>
		<!--REMEMBER PASSWORD-->
		<Grid Grid.Row="2" Margin="0,5,0,0">
			<CheckBox Name="chkRememberPassword" Content="记住密码" IsChecked="True" HorizontalAlignment="Right"/>
		</Grid>
		<!--LOGIN BUTTON-->
		<Grid Grid.Row="4">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<ComboBox Grid.Column="0" Name="cbSPDURL" HorizontalAlignment="Stretch" IsEditable="False" Margin="0,0,5,0" DisplayMemberPath="Name" SelectedValuePath="Url"/>
			<Button 
				Grid.Column="1"
				Name="btnLogin"
				Content="登录"
				HorizontalAlignment="Right"
				Style="{StaticResource ButtonSuccess}"
				Click="BtnLogin_Click" Width="80"/>
		</Grid>
	</Grid>
</Window>
