<Window x:Class="Nimaime.SPD.MainWindow"
				xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				xmlns:local="clr-namespace:Nimaime.SPD"
				xmlns:controls="clr-namespace:Nimaime.SPD.Controls"
				xmlns:sys="clr-namespace:System;assembly=mscorlib"
				xmlns:hc="https://handyorg.github.io/handycontrol"
				mc:Ignorable="d"
				Title="二枚目国药SPD系统帮助程序" Height="720" Width="1280">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<!--程序头部 显示登录/配置 信息 更新-->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0">
				<Label Content="当前登录用户：未登录(双击此处登录)" HorizontalAlignment="Left" Name="lblLoginStatus" MouseDoubleClick="lblLoginStatus_MouseDoubleClick"/>
			</StackPanel>
			<StackPanel Grid.Column="2" Orientation="Horizontal">
				<Button Name="btnHISDBSetting" Content="HIS数据库设置" HorizontalAlignment="Right" Click="btnHISDBSetting_Click" Margin="5,0,0,0"/>
				<Button Name="btnLogout" Content="注销" HorizontalAlignment="Right" Click="btnLogout_Click" Style="{StaticResource ButtonDanger}" Margin="5,0,0,0"/>
			</StackPanel>
		</Grid>
		<!--程序主部-->
		<Grid Grid.Row="1">
			<TabControl Name="tabMain">
				<TabItem Header="基础数据">
					<controls:CtlMaterialBaseData x:Name="ctlMaterialBaseData"/>
				</TabItem>
				<TabItem Header="消耗查询">
					<Grid Background="#FFE5E5E5">
						<TabControl Name="tabConsume">
							<TabItem Header="消耗报表">
								<Grid Background="#FFE5E5E5">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="*"/>
									</Grid.RowDefinitions>
									<Grid Grid.Row="0">
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
											<Label Content="科室："/>
											<controls:SearchableComboBox x:Name="cbDeptInConsume" Width="120" VerticalAlignment="Top" DisplayMemberPath="EName"/>
											<DatePicker
												hc:InfoElement.Necessary="True"
												Style="{StaticResource DatePickerExtend}"
												hc:InfoElement.TitlePlacement="Left"
												hc:InfoElement.Title="起始日期"
												Name="dpStartDate"
												DisplayDateStart="2022-07-01"
												SelectedDate="{x:Static sys:DateTime.Now}"
												Width="180"/>
											<DatePicker
												hc:InfoElement.Necessary="True"
												Style="{StaticResource DatePickerExtend}"
												hc:InfoElement.TitlePlacement="Left"
												hc:InfoElement.Title="结束日期"
												Name="dpEndDate"
												DisplayDateStart="2022-07-01"
												SelectedDate="{x:Static sys:DateTime.Now}"
												Width="180"/>
											<Button Name="btnSetLastFinanceMonth" Content="一键设为上个财务月" Click="btnSetLastFinanceMonth_Click"/>
										</StackPanel>
									</Grid>
								</Grid>
							</TabItem>
							<TabItem Header="高值追溯">
								<Grid Background="#FFE5E5E5">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="*"/>
									</Grid.RowDefinitions>
									<Grid Grid.Row="0">
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
											<Label Content="唯一码："/>
											<TextBox x:Name="txtEPC" Width="128"/>
											<Button Name="btnTrackEPC" Content="查询" Click="btnTrackEPC_Click" Margin="5,0,0,0"/>
											<Button Name="btnTrackEPCByExcel" Content="表格批量查询" Click="btnTrackEPCByExcel_Click" Margin="5,0,0,0"/>
										</StackPanel>
									</Grid>
								</Grid>
							</TabItem>
						</TabControl>
					</Grid>
				</TabItem>
				<TabItem Header="后勤物资">
					<Grid Background="#FFE5E5E5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>
						<Grid Grid.Row="0">
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
								<Button 
									Name="btnFetchDeptByImmRK"
									Margin="5"
									Content="后勤出入库报表补充退库科室"
									Click="btnFetchDeptByImmRK_Click"/>
							</StackPanel>
						</Grid>
					</Grid>
				</TabItem>
			</TabControl>
		</Grid>
	</Grid>
</Window>
