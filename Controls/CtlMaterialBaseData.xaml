<UserControl x:Class="Nimaime.SPD.Controls.CtlMaterialBaseData"
						 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
						 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
						 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
						 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
						 xmlns:local="clr-namespace:Nimaime.SPD.Controls"
						 mc:Ignorable="d" 
						 xmlns:hc="https://handyorg.github.io/handycontrol"
						 d:DesignHeight="600" d:DesignWidth="1652.5">
	<Grid Background="#FFE5E5E5">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<!--查询参数设置-->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" Orientation="Horizontal">
				<TextBox Margin="5,0,0,0"
								hc:InfoElement.TitlePlacement="Left"
								hc:InfoElement.Title="关键词"
								Style="{StaticResource TextBoxExtend}"
								x:Name="txtKeyword" Width="120"/>
				<local:SearchableComboBox Margin="5,0,0,0"
								ItemsSource="{Binding Providers, Mode=OneWay}"
								hc:InfoElement.TitlePlacement="Left"
								hc:InfoElement.Title="供应商"
								Style="{StaticResource ComboBoxExtend}"
								x:Name="cbProviderInMaterial"
								Width="240"
								DisplayMemberPath="cname"
								IsEditable="True"/>
				<TextBox Margin="5,0,0,0"
								hc:InfoElement.TitlePlacement="Left"
								hc:InfoElement.Title="厂家"
								Style="{StaticResource TextBoxExtend}"
								x:Name="txtManufacturer" Width="160"/>
				<ComboBox
					hc:InfoElement.TitlePlacement="Left"
					hc:InfoElement.Title="类型"
					Style="{StaticResource ComboBoxExtend}"
					x:Name="cbMaterialType"
					Width="120"/>
				<CheckBox Margin="5,0,0,0" x:Name="chkIsMaterialEnabled" Content="是否激活" IsThreeState="True" IsChecked="True"/>
				<CheckBox Margin="5,0,0,0" x:Name="chkIsMaterialProcurement" Content="是否采购" IsThreeState="True" IsChecked="{x:Null}"/>
				<CheckBox Margin="5,0,0,0" x:Name="chkIsMaterialTemporaryProcurement" Content="是否临采" IsThreeState="True" IsChecked="{x:Null}"/>
				<CheckBox Margin="5,0,0,0" x:Name="chkIsMaterialCharging" Content="是否收费" IsThreeState="True" IsChecked="{x:Null}"/>
				<CheckBox Margin="5,0,0,0" x:Name="chkIsMaterialContract" Content="是否带量" IsThreeState="True" IsChecked="{x:Null}"/>

				<Button Name="btnLoadMaterial" Content="加载" Margin="5,0,0,0" Click="btnLoadMaterial_Click"/>
				<Button Name="btnExportMaterialWithPara" Content="导出" Click="btnExportMaterialWithPara_Click" Margin="5,0,0,0"/>
			</StackPanel>
			<Grid Grid.Column="1">
				<WrapPanel/>
			</Grid>
			<Grid Grid.Column="2">
				<Button Name="btnExportMaterialXLS" Content="导出全部耗材" Click="btnExportMaterialXLS_Click"/>
			</Grid>
		</Grid>
		<!--表格-->
		<Grid Grid.Row="1">
			<DataGrid
						x:Name="dgMaterial"
						AutoGenerateColumns="False"
						SelectionMode="Extended"
						CanUserResizeRows="False"
						IsSynchronizedWithCurrentItem="False"
						ContextMenu="{Binding menuDGMaterial}"
						Style="{StaticResource DataGrid.Small}"
						MouseRightButtonDown="dgMaterial_MouseRightButtonDown">
				<DataGrid.Columns>
					<DataGridTextColumn Header="ID" Binding="{Binding SPDID}" IsReadOnly="True"/>
					<DataGridTextColumn Header="HIS编码" Binding="{Binding erpCode}" IsReadOnly="True"/>
					<DataGridTextColumn Header="启停" Binding="{Binding flagStr}" IsReadOnly="True"/>
					<DataGridTextColumn Header="采购状态" Binding="{Binding purchaseStatus}" IsReadOnly="True"/>
					<DataGridTextColumn Header="类型" Binding="{Binding purType}" IsReadOnly="True"/>
					<DataGridTextColumn Header="名称" Binding="{Binding goodsName}" IsReadOnly="True"/>
					<DataGridTextColumn Header="规格" Binding="{Binding goodsGg}" IsReadOnly="True"/>
					<DataGridTextColumn Header="价格" Binding="{Binding price, StringFormat={}{0:F2}}" IsReadOnly="True"/>
					<DataGridTextColumn Header="供应商" Binding="{Binding provName}" IsReadOnly="True"/>
					<DataGridTextColumn Header="厂家" Binding="{Binding mfrsName}" IsReadOnly="True"/>
					<DataGridTextColumn Header="财务分类" Binding="{Binding hosKindName}" IsReadOnly="True"/>
					<DataGridTextColumn Header="收费" Binding="{Binding isCharging}" IsReadOnly="True"/>
					<DataGridTextColumn Header="带量" Binding="{Binding purchaseContract}" IsReadOnly="True"/>
					<DataGridTextColumn Header="平台编码" Binding="{Binding hitCode}" IsReadOnly="True"/>
					<DataGridTextColumn Header="医保编码" Binding="{Binding icdCode}" IsReadOnly="True"/>
					<DataGridTextColumn Header="注册证号" Binding="{Binding certificateCode}" IsReadOnly="True"/>
					<DataGridTextColumn Header="导入人" Binding="{Binding ename}" IsReadOnly="True"/>
					<DataGridTextColumn Header="导入时间" Binding="{Binding fillDate, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" IsReadOnly="True"/>
					<DataGridTextColumn Header="更新时间" Binding="{Binding lastUpdateDatetime, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" IsReadOnly="True"/>
				</DataGrid.Columns>
			</DataGrid>
		</Grid>
		<!--翻页器-->
		<Grid Grid.Row="2">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
				<Label Name="lblDGMatCount" Content="共 0 条" Margin="0,0,5,0"/>
				<ComboBox
					Style="{StaticResource ComboBoxExtend}"
					x:Name="cbMaterialDGPager"
					Width="136"/>
				<Button Name="btnDGMatFirstPage" Content="首页" Click="btnDGMatFirstPage_Click" IsEnabled="False"/>
				<Button Name="btnDGMatPrevPage" Content="◀" Click="btnDGMatPrevPage_Click" IsEnabled="False"/>
				<Label Name="lblDGMatPage" Content="0/0" Margin="5,0,5,0"/>
				<Button Name="btnDGMatNextPage" Content="▶" Click="btnDGMatNextPage_Click" IsEnabled="False"/>
				<Button Name="btnDGMatLastPage" Content="尾页" Click="btnDGMatLastPage_Click" IsEnabled="False"/>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
