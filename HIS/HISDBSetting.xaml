<Window x:Class="Nimaime.SPD.HIS.HISDBSetting"
				xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				xmlns:local="clr-namespace:Nimaime.SPD"
				mc:Ignorable="d"
				xmlns:hc="https://handyorg.github.io/handycontrol"
				Title="数据库配置" Height="180" Width="320">

	<Grid Margin="5">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- 数据库地址 -->
		<hc:ComboBox Grid.Row="0" Name="cbDbServer"
				hc:InfoElement.TitlePlacement="Left"
				hc:InfoElement.Title="地址"
				hc:InfoElement.Necessary="True"
				DisplayMemberPath="Name"
				SelectedValuePath="Value"/>

		<!-- 用户名 -->
		<TextBox Grid.Row="1" Name="txtDbUser"
				VerticalAlignment="Center"
				hc:InfoElement.TitlePlacement="Left"
				hc:InfoElement.Title="账号"
				hc:InfoElement.Necessary="True"
				Style="{StaticResource TextBoxExtend}"
				Margin="0,5,0,0"/>

		<!-- 密码 -->
		<PasswordBox Grid.Row="2" Name="txtDbPassword"
				VerticalAlignment="Center"
				hc:InfoElement.TitlePlacement="Left"
				hc:InfoElement.Title="密码"
				hc:InfoElement.Necessary="True"
				Style="{StaticResource PasswordBoxExtend}"
				Margin="0,5,0,0"/>

		<!-- 保存按钮 -->
		<Grid Grid.Row="4">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Button Grid.Column="1"
				Name="btnTest"
				Content="测试连接"
				Width="100"
				Margin="0,0,5,0"
				Click="BtnTest_Click"/>

			<Button Grid.Column="2"
				Name="btnSave"
				Content="保存"
				Width="100"
				Click="BtnSave_Click"/>
		</Grid>
	</Grid>
</Window>